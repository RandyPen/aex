{
  "name": "@human.tech/create-agent-wallet",
  "version": "0.0.1",
  "description": "Scaffold a WaaP agent project in 3 minutes",
  "bin": {
    "create-agent-wallet": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/holonym-foundation/aex.git",
    "directory": "packages/create-agent-wallet"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup && npm run copy-registry",
    "build-to-publish": "npm run build",
    "copy-registry": "node scripts/copy-registry.mjs",
    "build:registry": "npx tsx registry/build/build-registry.ts",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.4",
    "vitest": "^2.0.0"
  }
}
