    "proper-lockfile": "^4.1.2",
    "viem": "^2.21.55",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.4",
    "vitest": "^2.0.0"
  }
}
