    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.2",
    "pg": "^8.21.0",
