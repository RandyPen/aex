{
  "name": "@human.tech/aex-fleet",
  "version": "0.0.1",
  "description": "Multi-agent operator CLI for WaaP wallets",
  "bin": {
    "aex-fleet": "./dist/index.js",
    "axf": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "public",
    "examples",
    "README.md",
    "SKILL.md",
    "templates"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/holonym-foundation/aex.git",
    "directory": "packages/aex-fleet"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
