# Cetus Yield Agent (Sui)
# https://docs.wallet.human.tech/recipes/cetus-yield-agent

# REQUIRED — Cetus pool object ID. Example below = SUI/USDC mainnet.
CETUS_POOL_ID=0xb8d7d9e66a60c239e7a60110efcf8de6c705580ed924d0dde141f4a0e2c90105

# Mode — `monitor` (Phase 1, read-only) or `active` (Phase 2+, real positions).
# Always start in monitor mode. Switch to active only after you've watched it for a few cycles.
AGENT_MODE=monitor

# Strategy
POSITION_RANGE_TICKS=200            # half-width of the position's tick range (used as fallback / minimum)
REBALANCE_THRESHOLD_TICKS=100       # drift in ticks from position center before rebalancing
CHECK_INTERVAL_MS=300000            # 5 minutes per recipe

# Volatility-adaptive range (Phase 3) — agent widens position range during high volatility,
# narrows during low volatility, to balance fee capture against rebalance frequency.
VOLATILITY_WINDOW=60                # rolling cycles for std-dev calculation
MIN_RANGE_TICKS=100
MAX_RANGE_TICKS=400
VOLATILITY_MULTIPLIER=3.0           # adaptive_range = volatility * multiplier * 2

# Position sizing (active mode)
USDC_OPEN_FRACTION=0.40             # fraction of USDC balance to deploy on initial open
USDC_REOPEN_FRACTION=0.50           # fraction to deploy on each rebalance reopen

# Network
NETWORK=mainnet                     # or testnet
# Optional override of the Sui gRPC endpoint used for ALL chain access
# (reads, finality waits, simulation). When unset, the cetus SDK uses its
# built-in mainnet/testnet defaults. Both SUI_RPC and SUI_GRPC_URL are
# accepted — SUI_RPC takes precedence so existing operator configs keep
# working when the agent migrated from JSON-RPC to gRPC.
# SUI_RPC=https://fullnode.mainnet.sui.io:443
# SUI_GRPC_URL=https://fullnode.mainnet.sui.io:443
# USDC_TYPE=                        # override default Sui USDC coin type if needed

# Dry-run safety — when true, every tx is simulated via the v2 Sui gRPC
# `simulateTransaction` endpoint instead of submitted via waap-cli.
# Effects, gas, and balance changes are logged so operators can verify a
# planned action before flipping back to live submission. Active mode +
# DRY_RUN=true is the recommended path for first-run validation of a new pool.
# DRY_RUN=false

# Volatility-adaptive strategy floor — minimum tick samples required before
# the adaptive half-width kicks in. Below this, decideRange() falls back to
# POSITION_RANGE_TICKS. Raise to require a longer warm-up.
# MIN_SAMPLES_FOR_ADAPTIVE=10

# Rebalance intent file — written before each on-chain step of a rebalance
# (remove → open) and reconciled at startup. Lets the agent refuse to
# auto-recover from a crash that happened between remove and open.
# INTENT_FILE=./agent.intent.json

# Optional safety rails
# AGENT_MAX_DEPOSIT_USD=1000        # hard cap on deployed USD (skips rebalances/opens that exceed)
ESTIMATED_GAS_SUI=0.01              # rough per-tx gas estimate for accumulating totalGasSpent

# Optional — bypass `waap-cli whoami` on startup. Set to the agent's Sui wallet
# address when the host doesn't maintain an interactive waap-cli session
# (credentials in env, transactions sent stateless via `waap-cli send-tx`).
# WAAP_AGENT_ADDRESS=0x...

# Yield scanner (Phases 4+5) — runs every Nth cycle, queries DeFi Llama for cross-protocol comparison
YIELD_SCAN_INTERVAL=6               # every 6th cycle (~30 min at 5-min check interval)

# Startup safety
STARTUP_COOLDOWN_MS=60000           # wait 60s after start before opening new positions

# Optional structured log file (JSON-line). Defaults to <projectName>.log in cwd.
# LOG_FILE=./agent.log

# Watchdog / supervisor integration. The agent writes its PID on startup so an
# external supervisor (systemd, monit, a bash watchdog) can detect liveness and
# restart on crash. Defaults to enabled to match the aex Hetzner deployment
# pattern. Set to false for local dev if you find stale .pid files annoying.
# WRITE_PID_FILE=true
# PID_FILE=./agent.pid

# Optional Matrix alerting on errors and rebalances
# MATRIX_HOMESERVER=https://your.matrix.homeserver
# MATRIX_ACCESS_TOKEN=
# MATRIX_ALERT_ROOM=!roomid:matrix.org
