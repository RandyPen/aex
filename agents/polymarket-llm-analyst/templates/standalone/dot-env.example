# Generated by @human.tech/create-agent-wallet
# Activity: Polymarket LLM Analyst

# --- LLM Configuration (REQUIRED) -------------------------------------------

# LLM provider for market analysis. Supported: "anthropic" or "openai"
LLM_PROVIDER=

# API key for the configured LLM provider
LLM_API_KEY=

# Minimum confidence score (0-1) to place a bet. Default: 0.7
# CONFIDENCE_THRESHOLD=0.7

# Milliseconds between LLM API calls for rate limiting. Default: 1000
# LLM_DELAY_MS=1000

# --- Agent Configuration ----------------------------------------------------

# Polymarket CLOB API endpoint
# POLYMARKET_API_URL=https://clob.polymarket.com

# Milliseconds between market polls
# AGENT_POLL_INTERVAL_MS=60000

# Maximum USD value per order (hard cap enforced by the agent) -- REQUIRED
AGENT_MAX_ORDER_USD=

# --- Polymarket CLOB L2 auth headers ----------------------------------------
# Required only for ORDER SUBMISSION. Read-only market polling works without these.
# Mint creds via Polymarket's clob-client deriveApiKey() or POST /auth/derive-api-key
# (signed L1 EIP-712 with your wallet). See https://docs.polymarket.com/developers/CLOB/authentication
# Returned credentials map to these vars:
#   POLY_API_KEY     <- apiKey
#   POLY_API_SECRET  <- secret  (used to HMAC the POLY_SIGNATURE header)
#   POLY_PASSPHRASE  <- passphrase
# POLY_ADDRESS defaults to your waap-cli whoami evmWalletAddress when omitted.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
# POLY_ADDRESS=
