# Generated by @human.tech/create-agent-wallet
# Activity: Recurring Payments Agent

# Path to the JSON config file defining payment schedules — REQUIRED
PAYMENT_CONFIG_PATH=./payments.json

# Default EVM chain ID (Base = 8453, Ethereum = 1, Polygon = 137)
# DEFAULT_CHAIN_ID=8453

# Milliseconds between payment-due checks (default: 60000 = 1 minute)
# AGENT_POLL_INTERVAL_MS=60000

# Path to the local JSON file that tracks payment history
# PAYMENT_HISTORY_PATH=./data/payment-history.json

# Path to the structured log file (JSONL format for AEX dashboard ingest)
# AGENT_LOG_FILE=./logs/recurring-payments.jsonl

# Set to 1 to log payment intents without submitting on-chain transactions
# AGENT_DRY_RUN=0

# Watchdog / supervisor integration — agent writes its PID on startup so an
# external supervisor (systemd, monit, watchdog) can detect liveness and
# restart on crash. Defaults to enabled to match the aex Hetzner deployment
# pattern. Set to false for local dev if stale .pid files are annoying.
# WRITE_PID_FILE=true
# PID_FILE=./agent.pid
