# Generated by @human.tech/create-agent-wallet
# Activity: Polymarket Arbitrage Agent

# Polymarket CLOB API endpoint
# POLYMARKET_API_URL=https://clob.polymarket.com

# Milliseconds between arbitrage scans (default: 30s -- faster than signal trader
# because arbitrage opportunities are time-sensitive)
# AGENT_POLL_INTERVAL_MS=30000

# Maximum USD value per order leg (hard cap enforced by the agent) -- REQUIRED
AGENT_MAX_ORDER_USD=

# Minimum spread in basis points to trigger an arbitrage trade.
# 50 bps = 0.5%. Set higher for conservative mode, lower for aggressive.
# Must exceed Polymarket fee structure (~2% round-trip) to be profitable.
# MIN_SPREAD_BPS=50

# --- Polymarket CLOB L2 auth headers ---
# Required for ORDER SUBMISSION. Read-only market polling works without these.
# Mint creds via Polymarket's clob-client deriveApiKey() or POST /auth/derive-api-key
# (signed L1 EIP-712 with your wallet). See https://docs.polymarket.com/developers/CLOB/authentication
# Returned credentials map to these vars:
#   POLY_API_KEY     <- apiKey
#   POLY_API_SECRET  <- secret  (used to HMAC the POLY_SIGNATURE header)
#   POLY_PASSPHRASE  <- passphrase
# POLY_ADDRESS defaults to your waap-cli whoami evmWalletAddress when omitted.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
# POLY_ADDRESS=

# Optional — Watchdog / supervisor integration. The agent writes its PID on
# startup so an external supervisor (systemd, monit, watchdog) can detect
# liveness and restart on crash. Defaults to enabled to match the aex Hetzner
# deployment pattern. Set to false for local dev if stale .pid files annoy.
# WRITE_PID_FILE=true
# PID_FILE=./agent.pid
