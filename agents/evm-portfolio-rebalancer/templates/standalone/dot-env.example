# Generated by @human.tech/create-agent-wallet
# Activity: Portfolio Rebalancer (EVM)

# ─── Token pair ──────────────────────────────────────────────────────────────
# Address of the token to rebalance (e.g. WETH on Base)
TARGET_TOKEN=

# Address of the quote/stable token (e.g. USDC on Base)
QUOTE_TOKEN=

# ─── Strategy parameters ─────────────────────────────────────────────────────
# Target USD value of TARGET_TOKEN holdings to maintain
TARGET_ALLOCATION_USD=1000

# Sell when price rises above this threshold
HIGH_PRICE_THRESHOLD=

# Buy when price falls below this threshold
LOW_PRICE_THRESHOLD=

# ─── DEX configuration ───────────────────────────────────────────────────────
# Uniswap V3 SwapRouter02 address
DEX_ROUTER=

# Uniswap V3 pool address for TARGET_TOKEN/QUOTE_TOKEN
POOL_ADDRESS=

# Pool fee tier in bps (500 = 0.05%, 3000 = 0.3%, 10000 = 1%)
# POOL_FEE=3000

# Whether TARGET_TOKEN is token0 in the pool (set false if QUOTE_TOKEN is token0)
# TOKEN0_IS_TARGET=true

# ─── Token decimals ──────────────────────────────────────────────────────────
# TARGET_DECIMALS=18
# QUOTE_DECIMALS=6

# ─── Tuning ──────────────────────────────────────────────────────────────────
# Milliseconds between price checks (default 30000)
# POLL_INTERVAL_MS=30000

# Maximum slippage in basis points (default 50 = 0.5%)
# SLIPPAGE_BPS=50

# Path to structured log file
# AGENT_LOG_FILE=./logs/rebalancer.jsonl

# ─── Watchdog / supervisor integration ───────────────────────────────────────
# The agent writes its PID on startup so an external supervisor (systemd,
# monit, a bash watchdog) can detect liveness and restart on crash. Defaults
# to enabled to match the aex Hetzner deployment pattern. Set to false for
# local dev if you find stale .pid files annoying.
# WRITE_PID_FILE=true
# PID_FILE=./agent.pid
