# Portfolio Rebalancer (Sui) -- Cetus DEX
# https://docs.wallet.human.tech/recipes/sui-portfolio-rebalancer

# REQUIRED -- target token to rebalance (Sui type string)
TARGET_TOKEN_TYPE=0x2::sui::SUI

# REQUIRED -- quote token for pricing and swaps
QUOTE_TOKEN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC

# REQUIRED -- target USD allocation of the target token to maintain
TARGET_ALLOCATION_USD=500

# REQUIRED -- sell target token when price reaches this level (USD)
HIGH_PRICE_THRESHOLD=4.50

# REQUIRED -- buy target token when price drops to this level (USD)
LOW_PRICE_THRESHOLD=3.00

# REQUIRED -- Cetus pool object ID for target/quote pair
# Example below = SUI/USDC mainnet
CETUS_POOL_ID=0xb8d7d9e66a60c239e7a60110efcf8de6c705580ed924d0dde141f4a0e2c90105

# Polling interval in milliseconds (default 60 seconds)
POLL_INTERVAL_MS=60000

# Max slippage in basis points (default 50 = 0.5%)
SLIPPAGE_BPS=50

# Network: mainnet or testnet
NETWORK=mainnet

# Optional Sui RPC override
# SUI_RPC=https://fullnode.mainnet.sui.io:443

# Optional Cetus aggregator API endpoint override
# CETUS_AGGREGATOR_URL=https://api-sui.cetus.zone/router_v2

# Optional -- bypass waap-cli whoami by setting the agent wallet address directly
# WAAP_AGENT_ADDRESS=0x...

# Optional structured log file (JSON-line). Defaults to ./logs/<agentId>.jsonl
# AGENT_LOG_FILE=./logs/rebalancer.jsonl
