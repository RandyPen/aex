# GitHub auth — pick ONE path:
#
# Path A (direct, simplest): personal access token with repo + actions scopes.
# Lives in this .env file as plaintext. Fine for local dev or non-TAP deploys.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Path B (proxied via TAP, preferred when TAP is available): the token never
# touches this file. All three of TAP_PROXY_URL, TAP_AGENT_KEY, and
# GITHUB_TAP_CREDENTIAL must be set for the agent to switch into TAP mode.
# TAP_PROXY_URL=https://tap.example.com
# TAP_AGENT_KEY=
# GITHUB_TAP_CREDENTIAL=github-test-waap-aex

# Required — Comma-separated repos to monitor
GITHUB_REPOS=owner/repo1,owner/repo2

# Required — Staging/preview environment base URL to run wallet tests against
STAGING_URL=https://staging.myapp.xyz

# Required — Contract address for contract interaction tests
TEST_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Required — ERC-20 token address for approval tests
TEST_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — Polling interval in milliseconds (default: 30000)
POLL_INTERVAL_MS=30000

# Optional — Structured log file path (default: ./logs/cicd-agent.jsonl)
AGENT_LOG_FILE=./logs/cicd-agent.jsonl

# Optional — Webhook URL for deploy-on-merge (e.g. Vercel deploy hook)
DEPLOY_WEBHOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxxxx/xxxxx

# Optional — GitHub Actions workflow file to dispatch for CI (default: ci.yml)
CI_WORKFLOW_ID=ci.yml

# Optional — ETH amount for the transaction test, sent to self on testnet (default: 0.0001)
TEST_SEND_AMOUNT_ETH=0.0001

# Optional — Hex-encoded calldata for contract interaction test (default: 0x)
TEST_CONTRACT_METHOD=0x

# Optional — Watchdog / supervisor integration. The agent writes its PID on
# startup so an external supervisor (systemd, monit, watchdog) can detect
# liveness and restart on crash. Defaults to enabled to match the aex Hetzner
# deployment pattern. Set to false for local dev if stale .pid files annoy.
# WRITE_PID_FILE=true
# PID_FILE=./agent.pid
