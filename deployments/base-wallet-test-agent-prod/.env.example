# base-wallet-test-agent-prod — live deployment env shape.
# Real values live in /home/agents/base-wallet-test-agent/.env on the aex host.

# Required — GitHub personal access token (needs repo + actions scopes)
GITHUB_TOKEN=

# Required — Comma-separated repos to monitor
GITHUB_REPOS=

# Required — Staging/preview environment base URL to run wallet tests against
STAGING_URL=

# Required — Contract address for contract interaction tests
TEST_CONTRACT_ADDRESS=

# Required — ERC-20 token address for approval tests
TEST_TOKEN_ADDRESS=

# Chain
CHAIN_ID=8453

# Optional — Polling interval in milliseconds (default: 30000)
POLL_INTERVAL_MS=30000

# Optional — Webhook URL for deploy-on-merge
# DEPLOY_WEBHOOK_URL=

# Optional — GitHub Actions workflow file to dispatch for CI (default: ci.yml)
# CI_WORKFLOW_ID=ci.yml

# Optional — ETH amount for the transaction test
# TEST_SEND_AMOUNT_ETH=0.0001

# Optional — Hex-encoded calldata for contract interaction test
# TEST_CONTRACT_METHOD=0x

# WaaP — bypass interactive whoami; address must match the deployment record
WAAP_AGENT_ADDRESS=0x1B5Bce84dBd943c21e6a659CE5DeF24Fdae9D72a
WAAP_CLI_SESSION_DIR=/home/agents/base-wallet-test-agent/.waap-session

# Logging
LOG_FILE=/home/agents/logs/base-wallet-test-agent.stdout.log
AGENT_LOG_FILE=./logs/cicd-agent.jsonl
