# polygon-polymarket-arb-prod — live deployment env shape.
# Real values live in /home/agents/polygon-polymarket-arb/.env on the aex host.

# Polymarket CLOB API endpoint
# POLYMARKET_API_URL=https://clob.polymarket.com

# Milliseconds between arbitrage scans (default: 30s)
# AGENT_POLL_INTERVAL_MS=30000

# Maximum USD value per order leg (hard cap enforced by the agent) -- REQUIRED
AGENT_MAX_ORDER_USD=5

# Minimum spread in basis points to trigger an arbitrage trade.
# MIN_SPREAD_BPS=50

# --- Polymarket CLOB L2 auth headers ----------------------------------------
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_ADDRESS=0xF65c65E4170141a7deC990Ae3640B96f2592F617

# WaaP — bypass interactive whoami; address must match the deployment record
WAAP_AGENT_ADDRESS=0xF65c65E4170141a7deC990Ae3640B96f2592F617
WAAP_CLI_SESSION_DIR=/home/agents/polygon-polymarket-arb/.waap-session

# Logging
LOG_FILE=/home/agents/logs/polygon-polymarket-arb.stdout.log
