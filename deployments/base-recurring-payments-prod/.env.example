# base-recurring-payments-prod — live deployment env shape.
# Real values live in /home/agents/base-recurring-payments/.env on the aex host.

# Path to the JSON config file defining payment schedules — REQUIRED
PAYMENT_CONFIG_PATH=./payments.json

# Default EVM chain ID
DEFAULT_CHAIN_ID=8453

# Milliseconds between payment-due checks (default: 60000 = 1 minute)
# AGENT_POLL_INTERVAL_MS=60000

# Path to the local JSON file that tracks payment history
# PAYMENT_HISTORY_PATH=./data/payment-history.json

# Set to 1 to log payment intents without submitting on-chain transactions
AGENT_DRY_RUN=1

# WaaP — bypass interactive whoami; address must match the deployment record
WAAP_AGENT_ADDRESS=0xa16094B83B2da2779F9583aa796576B10a5EBa0d
WAAP_CLI_SESSION_DIR=/home/agents/base-recurring-payments/.waap-session

# Logging
LOG_FILE=/home/agents/logs/base-recurring-payments.stdout.log
# AGENT_LOG_FILE=./logs/recurring-payments.jsonl
