# base-evm-portfolio-rebalancer-prod — live deployment env shape.
# Real values live in /home/agents/base-portfolio-rebalancer/.env on the aex host.

# ─── Token pair ──────────────────────────────────────────────────────────────
# Address of the token to rebalance (e.g. WETH on Base)
TARGET_TOKEN=

# Address of the quote/stable token (e.g. USDC on Base)
QUOTE_TOKEN=

# ─── Chain ───────────────────────────────────────────────────────────────────
CHAIN_ID=8453
RPC_URL=                             # set to a private RPC (Alchemy/Infura/QuickNode)

# ─── Strategy parameters ─────────────────────────────────────────────────────
TARGET_ALLOCATION_USD=1000
HIGH_PRICE_THRESHOLD=
LOW_PRICE_THRESHOLD=

# ─── DEX configuration ───────────────────────────────────────────────────────
# Uniswap V3 SwapRouter02 address
DEX_ROUTER=
POOL_ADDRESS=
# POOL_FEE=3000
# TOKEN0_IS_TARGET=true

# ─── Token decimals ──────────────────────────────────────────────────────────
# TARGET_DECIMALS=18
# QUOTE_DECIMALS=6

# ─── Tuning ──────────────────────────────────────────────────────────────────
# POLL_INTERVAL_MS=30000
# SLIPPAGE_BPS=50

# WaaP — bypass interactive whoami; address must match the deployment record
WAAP_AGENT_ADDRESS=0xa543197A1cf404115D350Fee6b785ad169387D35
WAAP_CLI_SESSION_DIR=/home/agents/base-portfolio-rebalancer/.waap-session

# Safety — keep dry-run on until live funding + first end-to-end smoke test
AGENT_DRY_RUN=1

# Logging
LOG_FILE=/home/agents/logs/base-portfolio-rebalancer.stdout.log
# AGENT_LOG_FILE=./logs/rebalancer.jsonl
