# sui-cetus-yield-prod — env shape (real values on the host, never in git)
# See agents/cetus-yield-agent/templates/standalone/dot-env.example for the
# full upstream template. This file documents per-deployment overrides only.

# Identity (company-owned)
WAAP_EMAIL=webmaster+sui-cetus-yield@holonym.id
# WAAP_PASSWORD=<set on host via systemd-creds or .env on disk>

# Pool — SUI/USDC CLMM on Cetus mainnet
CETUS_POOL_ID=0xb8d7d9e66a60c239e7a60110efcf8de6c705580ed924d0dde141f4a0e2c90105

# Mode
AGENT_MODE=active

# Strategy — defaults match the template
POSITION_RANGE_TICKS=200
REBALANCE_THRESHOLD_TICKS=100
CHECK_INTERVAL_MS=300000
COMPOUND_FEES=true
NETWORK=mainnet

# Telemetry hooks (currently personal endpoints; rotate to company when wired)
# MATRIX_HOMESERVER=
# MATRIX_ACCESS_TOKEN=
# MATRIX_ALERT_ROOM=

# LOG_FILE=/home/agents/logs/cetus-yield.stdout.log  (set in systemd unit)
