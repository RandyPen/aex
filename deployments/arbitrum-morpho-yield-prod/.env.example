# arbitrum-morpho-yield-prod — live deployment env shape.
# Real values live in /home/agents/arbitrum-morpho-yield/.env on the aex host.

# REQUIRED — Arbitrum native USDC
AGENT_ASSET=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
AGENT_MAX_DEPOSIT_USD=500            # tune per funding round

# Chain
CHAIN_ID=42161
RPC_URL=                             # set to a private RPC (Alchemy/Infura/QuickNode)

# Strategy — multi-vault portfolio defaults
AGENT_PORTFOLIO_TOP_N=3
AGENT_REBAL_DRIFT_BPS=500
AGENT_MIN_APY_DELTA_BPS=50           # only consulted when TOP_N=1
AGENT_POLL_INTERVAL_MS=1800000       # 30 min

# Optional — explicit watched-vault allowlist (recommended for prod)
# WATCHED_VAULTS=

# Idle-fallback floor — Aave V3 on Arbitrum, native USDC supply
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_ATOKEN_ADDRESS=0x724dc807b04555b71ed48a6896b6F41593b8C637
AGENT_IDLE_FALLBACK_MIN_USD=1

# Reward claiming
REWARDS_API_URL=https://rewards.morpho.org/v1/users/{address}?chain_id={chainId}
AGENT_REWARDS_CLAIM_INTERVAL_MS=86400000
AGENT_REWARDS_MIN_CLAIM_WEI=1

# Matrix alerts (set on host, not committed)
# MATRIX_HOMESERVER=
# MATRIX_ACCESS_TOKEN=
# MATRIX_ALERT_ROOM=

# Pre-flight tx simulation — strongly recommended on prod
AGENT_SIMULATE=1

# Telegram approval gate (app-layer 2FA) — set on host, not committed
# TG_APPROVAL_BOT_TOKEN=
# TG_APPROVAL_CHAT_ID=
AGENT_TX_LIMIT_USD=50
AGENT_APPROVAL_TIMEOUT_MS=300000

# WaaP — bypass interactive whoami; address must match the deployment record
WAAP_AGENT_ADDRESS=0x24049951b0f2Df207F6b16d982072AF7CfAEd5f1
WAAP_CLI_SESSION_DIR=/home/agents/arbitrum-morpho-yield/.waap-session

# Safety — keep dry-run on until live funding + first end-to-end smoke test
AGENT_DRY_RUN=1

# Logging
LOG_FILE=/home/agents/logs/morpho-yield.stdout.log
