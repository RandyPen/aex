# polygon-polymarket-llm-prod — live deployment env shape.
# Real values live in /home/agents/polygon-polymarket-llm/.env on the aex host.

# --- LLM Configuration (REQUIRED) -------------------------------------------

# LLM provider for market analysis. Supported: "anthropic" or "openai"
LLM_PROVIDER=
LLM_API_KEY=

# Minimum confidence score (0-1) to place a bet. Default: 0.7
# CONFIDENCE_THRESHOLD=0.7

# Milliseconds between LLM API calls for rate limiting. Default: 1000
# LLM_DELAY_MS=1000

# --- Agent Configuration ----------------------------------------------------

# Polymarket CLOB API endpoint
# POLYMARKET_API_URL=https://clob.polymarket.com

# Milliseconds between market polls
# AGENT_POLL_INTERVAL_MS=60000

# Maximum USD value per order (hard cap enforced by the agent) -- REQUIRED
AGENT_MAX_ORDER_USD=5

# --- Polymarket CLOB L2 auth headers ----------------------------------------
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_ADDRESS=0x665cf64782DC323290f48c2DfEdf082753099404

# WaaP — bypass interactive whoami; address must match the deployment record
WAAP_AGENT_ADDRESS=0x665cf64782DC323290f48c2DfEdf082753099404
WAAP_CLI_SESSION_DIR=/home/agents/polygon-polymarket-llm/.waap-session

# Logging
LOG_FILE=/home/agents/logs/polygon-polymarket-llm.stdout.log
